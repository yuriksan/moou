DB_USER=moou
DB_PASSWORD=moou
DB_NAME=moou
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://moou:moou@db:5432/moou
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
EXTERNAL_PROVIDER=valueedge

# GitHub OAuth (only needed when EXTERNAL_PROVIDER=github)
# GITHUB_CLIENT_ID=your_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_oauth_app_client_secret
# GITHUB_CALLBACK_URL=http://localhost:3000/auth/callback
# GITHUB_REPO=org/repo

# Session encryption (required for OAuth, generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-64-char-hex-string-at-least-32-chars

# ValueEdge / ALM Octane (only needed when EXTERNAL_PROVIDER=valueedge)
# VALUEEDGE_BASE_URL=https://ot-internal.saas.microfocus.com
# VALUEEDGE_SHARED_SPACE=4001
# VALUEEDGE_WORKSPACE=48001
# Required for the publish (create item) flow — look up IDs via the ValueEdge UI or phases API
# VALUEEDGE_DEFAULT_EPIC_PHASE_ID=1001          # Phase ID for newly created Epics (e.g. "New")
# VALUEEDGE_DEFAULT_FEATURE_PHASE_ID=2001       # Phase ID for newly created Features
# VALUEEDGE_DEFAULT_STORY_PHASE_ID=3001         # Phase ID for newly created Stories
# VALUEEDGE_DEFAULT_PARENT_EPIC_ID=             # Default Epic ID to file new Features under
# VALUEEDGE_DEFAULT_PARENT_FEATURE_ID=          # Default Feature ID to file new Stories under
